allow hal_graphics_composer_default hal_sensors_service:service_manager find;
allow hal_graphics_composer_default vendor_hal_displayfeature_service:service_manager find;

binder_call(hal_graphics_composer_default, hal_sensors_default)
binder_call(hal_graphics_composer_default, vendor_hal_displayfeature_default)

allow hal_graphics_composer_default mnt_vendor_file:dir r_dir_perms;
allow hal_graphics_composer_default persist_data_file:dir r_dir_perms;
rw_dir_file(hal_graphics_composer_default, vendor_sysfs_displayfeature)
r_dir_file(hal_graphics_composer_default, vendor_persist_display_file)

get_prop(hal_graphics_composer_default, vendor_displayfeature_prop)
