allow hal_sensors_default fwk_sensor_service:service_manager find;

hal_client_domain(hal_sensors_default, hal_audio)

binder_call(hal_sensors_default, hal_audio_default)
binder_call(hal_sensors_default, hal_graphics_allocator_default)
binder_call(hal_sensors_default, hal_graphics_composer_default)

allow hal_sensors_default audio_socket:sock_file rw_file_perms;
allow hal_sensors_default sensors_device:chr_file r_file_perms;
allow hal_sensors_default hal_graphics_allocator_default_tmpfs:file rw_file_perms;
allow hal_sensors_default vendor_displayfeature_device:dir r_dir_perms;
allow hal_sensors_default vendor_displayfeature_device:chr_file r_file_perms;

r_dir_file(hal_sensors_default, sysfs_leds)
r_dir_file(hal_sensors_default, vendor_sysfs_displayfeature)
r_dir_file(hal_sensors_default, vendor_sysfs_touch)

get_prop(hal_sensors_default, vendor_displayfeature_prop)
