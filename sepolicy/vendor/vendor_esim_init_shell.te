type vendor_esim_init_shell, domain;
type vendor_esim_init_shell_exec, exec_type, vendor_file_type, file_type;

init_daemon_domain(vendor_esim_init_shell)

allow vendor_esim_init_shell vendor_shell_exec:file rx_file_perms;
allow vendor_esim_init_shell vendor_toolbox_exec:file rx_file_perms;

allow vendor_esim_init_shell vendor_mtkmtb_exec:file rx_file_perms;
allow vendor_esim_init_shell vendor_mtkmtb_exec:file execute_no_trans;
allow vendor_esim_init_shell sysfs_ccci:dir r_dir_perms;
allow vendor_esim_init_shell sysfs_ccci:file rw_file_perms;
allow vendor_esim_init_shell gsm0710muxd_device:chr_file rw_file_perms;

set_prop(vendor_esim_init_shell, vendor_esim_state_prop)
